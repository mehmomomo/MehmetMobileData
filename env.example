# Copy this file and rename it to .env
# Then fill in your actual keys

# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/mehmet-mobile-data

# Paystack
PAYSTACK_SECRET=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# VTPass
VTPASS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
